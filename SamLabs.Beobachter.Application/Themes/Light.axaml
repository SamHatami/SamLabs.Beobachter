<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#FFF4F6FA" />
    <SolidColorBrush x:Key="ShellPanelBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ShellForegroundBrush" Color="#FF1F2937" />
    <SolidColorBrush x:Key="ShellMutedForegroundBrush" Color="#FF6B7280" />
</ResourceDictionary>
