<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#FF0B1220" />
    <SolidColorBrush x:Key="ShellPanelBrush" Color="#FF111827" />
    <SolidColorBrush x:Key="ShellPanelBorderBrush" Color="#FF243042" />
    <SolidColorBrush x:Key="ShellChromeBrush" Color="#FF162033" />
    <SolidColorBrush x:Key="ShellChromeBorderBrush" Color="#FF314054" />
    <SolidColorBrush x:Key="ShellForegroundBrush" Color="#FFE5E7EB" />
    <SolidColorBrush x:Key="ShellMutedForegroundBrush" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="ShellAccentBrush" Color="#FF14B8A6" />
    <SolidColorBrush x:Key="ShellAccentForegroundBrush" Color="#FF081018" />
    <SolidColorBrush x:Key="SeverityBadgeForegroundBrush" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="ValidationErrorBrush" Color="#FFF87171" />
    <SolidColorBrush x:Key="RowTraceBrush" Color="#1A0EA5E9" />
    <SolidColorBrush x:Key="RowDebugBrush" Color="#1A6366F1" />
    <SolidColorBrush x:Key="RowInfoBrush" Color="#149CA3AF" />
    <SolidColorBrush x:Key="RowWarnBrush" Color="#33F59E0B" />
    <SolidColorBrush x:Key="RowErrorBrush" Color="#33EF4444" />
    <SolidColorBrush x:Key="RowFatalBrush" Color="#4DB91C1C" />
    <SolidColorBrush x:Key="RowFallbackBrush" Color="#00000000" />
    <SolidColorBrush x:Key="BadgeTraceBrush" Color="#FF0EA5E9" />
    <SolidColorBrush x:Key="BadgeDebugBrush" Color="#FF6366F1" />
    <SolidColorBrush x:Key="BadgeInfoBrush" Color="#FF2563EB" />
    <SolidColorBrush x:Key="BadgeWarnBrush" Color="#FFD97706" />
    <SolidColorBrush x:Key="BadgeErrorBrush" Color="#FFDC2626" />
    <SolidColorBrush x:Key="BadgeFatalBrush" Color="#FF7F1D1D" />
    <SolidColorBrush x:Key="BadgeFallbackBrush" Color="#FF475569" />
    <SolidColorBrush x:Key="MessageTraceBrush" Color="#FF38BDF8" />
    <SolidColorBrush x:Key="MessageDebugBrush" Color="#FFA5B4FC" />
    <SolidColorBrush x:Key="MessageInfoBrush" Color="#FF93C5FD" />
    <SolidColorBrush x:Key="MessageWarnBrush" Color="#FFFCD34D" />
    <SolidColorBrush x:Key="MessageErrorBrush" Color="#FFFCA5A5" />
    <SolidColorBrush x:Key="MessageFatalBrush" Color="#FFF87171" />
    <SolidColorBrush x:Key="MessageFallbackBrush" Color="#FFE5E7EB" />
</ResourceDictionary>
