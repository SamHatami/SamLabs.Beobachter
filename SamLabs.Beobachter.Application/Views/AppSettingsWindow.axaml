<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:vm="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
        x:Class="SamLabs.Beobachter.Application.Views.AppSettingsWindow"
        x:DataType="vm:AppSettingsViewModel"
        Width="680"
        Height="700"
        MinWidth="580"
        MinHeight="520"
        Title="Application Settings"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="Button.color-clear">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.4" />
        </Style>
        <Style Selector="Button.color-clear:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ColorPicker.compact-picker">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Styles>

    <Border Background="{DynamicResource ShellBackgroundBrush}">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Border Grid.Row="0"
                    Classes="shell-panel shell-flat shell-border-horizontal"
                    Padding="14,10">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="APPLICATION SETTINGS"
                               Classes="panel-title" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="Theme, capacity, and log level colors"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16">
                <StackPanel Spacing="20">

                    <!-- Release Notes -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="RELEASE NOTES"
                                       Classes="section-caption" />
                            <TextBlock Text="{Binding ReleaseVersion}"
                                       Classes="panel-title" />
                            <TextBlock Text="{Binding ReleasePublishedOn}"
                                       Classes="release-notes-meta" />
                            <TextBlock Text="{Binding ReleaseSummary}"
                                       Classes="release-notes-summary" />
                            <TextBlock Text="{Binding ReleaseSeenStatus}"
                                       Classes="release-notes-meta" />
                            <ItemsControl ItemsSource="{Binding ReleaseHighlights}"
                                          IsVisible="{Binding HasReleaseHighlights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Classes="release-note-item">
                                            <TextBlock Text="•"
                                                       Classes="release-note-bullet" />
                                            <TextBlock Text="{Binding}"
                                                       Classes="release-note-text" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Classes="toolbar-button"
                                    Content="Mark Release Notes As Seen"
                                    Command="{Binding MarkReleaseNotesSeenCommand}"
                                    IsVisible="{Binding !IsCurrentReleaseSeen}" />
                        </StackPanel>
                    </Border>

                    <!-- Theme Section -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="THEME"
                                       Classes="section-caption" />
                            <ComboBox SelectedIndex="{Binding SelectedThemeIndex}"
                                      MinWidth="200"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <i:Icon Value="fa-solid fa-circle-half-stroke" FontSize="12" />
                                        <TextBlock Text="System" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <i:Icon Value="fa-solid fa-sun" FontSize="12" />
                                        <TextBlock Text="Light" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <i:Icon Value="fa-solid fa-moon" FontSize="12" />
                                        <TextBlock Text="Dark" />
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Channel Capacity -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="LOG BUFFER CAPACITY"
                                       Classes="section-caption" />
                            <TextBlock Text="Maximum number of log entries held in memory. Requires restart to take effect."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <NumericUpDown Value="{Binding ChannelCapacity}"
                                           Minimum="1000"
                                           Maximum="1000000"
                                           Increment="5000"
                                           FormatString="N0"
                                           MinWidth="200"
                                           HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Log Level Colors -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="LOG LEVEL COLOR OVERRIDES"
                                       Classes="section-caption" />
                            <TextBlock Text="Pick a color to override the default. Clear resets to theme default."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <!-- Column headers -->
                            <Grid ColumnDefinitions="70,*,*,*"
                                  Margin="0,4,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="Level"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="Row"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Column="2"
                                           Text="Badge"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Column="3"
                                           Text="Message"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding LevelColors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LogLevelColorItemViewModel">
                                        <Grid ColumnDefinitions="70,*,*,*"
                                              Margin="0,2">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding LevelName}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ShellForegroundBrush}" />

                                            <!-- Row color -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        Margin="4,0">
                                                <ColorPicker Classes="compact-picker"
                                                             Color="{Binding RowColor}" />
                                                <Button Classes="color-clear"
                                                        Command="{Binding ClearRowColorCommand}"
                                                        ToolTip.Tip="Reset to default">
                                                    <i:Icon Value="fa-solid fa-xmark" FontSize="9" />
                                                </Button>
                                            </StackPanel>

                                            <!-- Badge color -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        Margin="4,0">
                                                <ColorPicker Classes="compact-picker"
                                                             Color="{Binding BadgeColor}" />
                                                <Button Classes="color-clear"
                                                        Command="{Binding ClearBadgeColorCommand}"
                                                        ToolTip.Tip="Reset to default">
                                                    <i:Icon Value="fa-solid fa-xmark" FontSize="9" />
                                                </Button>
                                            </StackPanel>

                                            <!-- Message color -->
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        Margin="4,0">
                                                <ColorPicker Classes="compact-picker"
                                                             Color="{Binding MessageColor}" />
                                                <Button Classes="color-clear"
                                                        Command="{Binding ClearMessageColorCommand}"
                                                        ToolTip.Tip="Reset to default">
                                                    <i:Icon Value="fa-solid fa-xmark" FontSize="9" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Classes="shell-panel shell-flat shell-border-horizontal"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Content="Cancel"
                            Classes="receiver-setup-button"
                            Click="OnCancelClick" />
                    <Button Content="Save"
                            Classes="receiver-setup-button primary"
                            Command="{Binding SaveCommand}"
                            Click="OnSaveClick" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
