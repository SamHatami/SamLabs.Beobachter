<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
        x:Class="SamLabs.Beobachter.Application.Views.AppSettingsWindow"
        x:DataType="viewModels:AppSettingsViewModel"
        Width="680"
        Height="700"
        MinWidth="580"
        MinHeight="520"
        Title="Application Settings"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <!-- Color swatch button: shows the selected color as background -->
        <Style Selector="Button.color-swatch">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.color-clear">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <Style Selector="Button.color-clear:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Window.Styles>

    <Border Background="{DynamicResource ShellBackgroundBrush}">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Border Grid.Row="0"
                    Classes="shell-panel shell-flat shell-border-horizontal"
                    Padding="14,10">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="APPLICATION SETTINGS"
                               Classes="panel-title" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="Theme, capacity, and log level colors"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16">
                <StackPanel Spacing="20">

                    <!-- Theme Section -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="THEME"
                                       Classes="section-caption" />
                            <ComboBox SelectedIndex="{Binding SelectedThemeIndex}"
                                      MinWidth="200"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <i:Icon Value="fa-solid fa-circle-half-stroke" FontSize="12" />
                                        <TextBlock Text="System" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <i:Icon Value="fa-solid fa-sun" FontSize="12" />
                                        <TextBlock Text="Light" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <i:Icon Value="fa-solid fa-moon" FontSize="12" />
                                        <TextBlock Text="Dark" />
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Channel Capacity -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="LOG BUFFER CAPACITY"
                                       Classes="section-caption" />
                            <TextBlock Text="Maximum number of log entries held in memory. Requires restart to take effect."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <NumericUpDown Value="{Binding ChannelCapacity}"
                                           Minimum="1000"
                                           Maximum="1000000"
                                           Increment="5000"
                                           FormatString="N0"
                                           MinWidth="200"
                                           HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Log Level Colors -->
                    <Border Classes="shell-card"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="LOG LEVEL COLOR OVERRIDES"
                                       Classes="section-caption" />
                            <TextBlock Text="Click a swatch to pick a color. Use the X button to reset to default."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <!-- Column headers -->
                            <Grid ColumnDefinitions="70,*,*,*"
                                  Margin="0,4,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="Level"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="Row"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Column="2"
                                           Text="Badge"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Column="3"
                                           Text="Message"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            </Grid>

                            <!-- Trace -->
                            <Grid ColumnDefinitions="70,*,*,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="Trace" VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding TraceRowColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="TraceRowColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="TraceRowColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding TraceBadgeColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="TraceBadgeColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="TraceBadgeColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding TraceMessageColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="TraceMessageColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="TraceMessageColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                            </Grid>

                            <!-- Debug -->
                            <Grid ColumnDefinitions="70,*,*,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="Debug" VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding DebugRowColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="DebugRowColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="DebugRowColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding DebugBadgeColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="DebugBadgeColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="DebugBadgeColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding DebugMessageColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="DebugMessageColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="DebugMessageColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                            </Grid>

                            <!-- Info -->
                            <Grid ColumnDefinitions="70,*,*,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="Info" VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding InfoRowColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="InfoRowColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="InfoRowColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding InfoBadgeColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="InfoBadgeColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="InfoBadgeColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding InfoMessageColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="InfoMessageColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="InfoMessageColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                            </Grid>

                            <!-- Warn -->
                            <Grid ColumnDefinitions="70,*,*,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="Warn" VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding WarnRowColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="WarnRowColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="WarnRowColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding WarnBadgeColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="WarnBadgeColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="WarnBadgeColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding WarnMessageColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="WarnMessageColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="WarnMessageColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                            </Grid>

                            <!-- Error -->
                            <Grid ColumnDefinitions="70,*,*,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="Error" VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding ErrorRowColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="ErrorRowColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="ErrorRowColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding ErrorBadgeColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="ErrorBadgeColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="ErrorBadgeColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding ErrorMessageColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="ErrorMessageColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="ErrorMessageColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                            </Grid>

                            <!-- Fatal -->
                            <Grid ColumnDefinitions="70,*,*,*" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="Fatal" VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding FatalRowColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="FatalRowColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="FatalRowColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding FatalBadgeColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="FatalBadgeColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="FatalBadgeColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="4,0">
                                    <Button Classes="color-swatch" Background="{Binding FatalMessageColor, Converter={x:Static viewModels:NullableColorToBrushConverter.Instance}}" Tag="FatalMessageColor" Click="OnColorSwatchClick" />
                                    <Button Classes="color-clear" Command="{Binding ClearColorCommand}" CommandParameter="FatalMessageColor" ToolTip.Tip="Reset to default"><i:Icon Value="fa-solid fa-xmark" FontSize="9" /></Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Classes="shell-panel shell-flat shell-border-horizontal"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Content="Cancel"
                            Classes="receiver-setup-button"
                            Click="OnCancelClick" />
                    <Button Content="Save"
                            Classes="receiver-setup-button primary"
                            Command="{Binding SaveCommand}"
                            Click="OnSaveClick" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
