<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SamLabs.Beobachter.Application.Views"
        xmlns:designViewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Design"
        xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="SamLabs.Beobachter.Application.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Beobachter"
        KeyDown="OnWindowKeyDown">

    <Design.DataContext>
        <designViewModels:MainWindowDesignViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource ShellBackgroundBrush}">

        <!-- Row 0: Top Bar -->
        <ContentControl x:Name="TopBarHost"
                        Grid.Row="0"
                        Content="{Binding TopBar}" />

        <!-- Row 1: Workspace (sidebar | splitter | stream | splitter | details) -->
        <Grid Grid.Row="1"
              ColumnDefinitions="240,Auto,*,Auto,340">

            <!-- Left sidebar: filters + sources -->
            <ContentControl Grid.Column="0"
                            Content="{Binding WorkspaceSidebar}" />

            <GridSplitter Grid.Column="1"
                          Width="1"
                          ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource ShellPanelBorderBrush}" />

            <!-- Center: log stream -->
            <ContentControl Grid.Column="2"
                            Content="{Binding Stream}" />

            <GridSplitter Grid.Column="3"
                          Width="1"
                          ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource ShellPanelBorderBrush}" />

            <!-- Right: entry details -->
            <ContentControl Grid.Column="4"
                            Content="{Binding Details}" />
        </Grid>

        <!-- Row 2: Bottom Status Strip -->
        <ContentControl Grid.Row="2"
                        Content="{Binding SessionHealth}" />
    </Grid>
</Window>
