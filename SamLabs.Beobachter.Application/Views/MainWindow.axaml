<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SamLabs.Beobachter.ViewModels"
        xmlns:models="using:SamLabs.Beobachter.Core.Models"
        xmlns:conv="using:SamLabs.Beobachter.Application.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="760"
        x:Class="SamLabs.Beobachter.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SamLabs.Beobachter"
        KeyDown="OnWindowKeyDown">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <conv:LogLevelToRowBrushConverter x:Key="LogLevelToRowBrushConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource ShellBackgroundBrush}">
        <Border Grid.Row="0"
                Margin="16,16,16,8"
                Padding="14"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Spacing="2">
                    <TextBlock Text="SamLabs.Beobachter"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <TextBlock Text="{Binding ThemeSummary}"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                    <TextBlock Text="{Binding StatusSummary}"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="System"
                            Command="{Binding UseSystemThemeCommand}" />
                    <Button Content="Light"
                            Command="{Binding UseLightThemeCommand}" />
                    <Button Content="Dark"
                            Command="{Binding UseDarkThemeCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,8"
                Padding="12"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="0"
                             Watermark="Search logger/message/exception/thread..."
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="Clear"
                            Command="{Binding ClearSearchCommand}" />
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Add Sample"
                            Command="{Binding GenerateSampleEntriesCommand}" />
                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Content="{Binding PauseButtonText}"
                            Command="{Binding TogglePauseCommand}" />
                    <Button Grid.Column="4"
                            Margin="8,0,0,0"
                            Content="{Binding AutoScrollButtonText}"
                            Command="{Binding ToggleAutoScrollCommand}" />
                    <Button Grid.Column="5"
                            Margin="8,0,0,0"
                            Content="{Binding DensityButtonText}"
                            Command="{Binding ToggleDensityCommand}" />
                </Grid>

                <WrapPanel Grid.Row="1"
                           Margin="0,8,0,0"
                           ItemHeight="56">
                    <StackPanel Width="140"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Receiver"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="udp-1"
                                 Text="{Binding ReceiverFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="200"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Logger"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="Orders.Api"
                                 Text="{Binding LoggerFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="140"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Thread"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="worker-7"
                                 Text="{Binding ThreadFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="130"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Tenant"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="alpha"
                                 Text="{Binding TenantFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="130"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Trace Id"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="abcd1234"
                                 Text="{Binding TraceIdFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="120"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Min Level"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <ComboBox ItemsSource="{Binding MinimumLevelOptions}"
                                  SelectedItem="{Binding MinimumLevelOption}" />
                    </StackPanel>
                    <Button Content="Clear Fields"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,0"
                            Command="{Binding ClearStructuredFiltersCommand}" />
                </WrapPanel>

                <WrapPanel Grid.Row="2"
                           Margin="0,8,0,0">
                    <CheckBox Content="Trace"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowTrace}" />
                    <CheckBox Content="Debug"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowDebug}" />
                    <CheckBox Content="Info"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowInfo}" />
                    <CheckBox Content="Warn"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowWarn}" />
                    <CheckBox Content="Error"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowError}" />
                    <CheckBox Content="Fatal"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowFatal}" />
                    <Button Content="Reset Levels"
                            Margin="0,0,10,0"
                            Command="{Binding ResetLevelsCommand}" />
                    <Button Content="Enable All Loggers"
                            Command="{Binding EnableAllLoggersCommand}" />
                </WrapPanel>

                <Expander Grid.Row="3"
                          Margin="0,10,0,0"
                          Header="Receiver Setup"
                          IsExpanded="False">
                    <Grid Margin="0,8,0,0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <ListBox Grid.Column="0"
                                 MinHeight="130"
                                 SelectedItem="{Binding SelectedReceiverDefinition}"
                                 ItemsSource="{Binding ReceiverDefinitions}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ReceiverDefinitionViewModel">
                                    <Border Margin="0,0,0,6"
                                            Padding="8"
                                            CornerRadius="6"
                                            Background="{DynamicResource ShellBackgroundBrush}">
                                        <Grid RowDefinitions="Auto,Auto,Auto"
                                              ColumnDefinitions="120,*,90">
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Kind}"
                                                       FontWeight="SemiBold" />
                                            <TextBox Grid.Row="0"
                                                     Grid.Column="1"
                                                     Margin="8,0,8,0"
                                                     Watermark="Display name"
                                                     Text="{Binding DisplayName}" />
                                            <CheckBox Grid.Row="0"
                                                      Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      Content="Enabled"
                                                      IsChecked="{Binding Enabled}" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="Id" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Grid.ColumnSpan="2"
                                                     Margin="8,6,0,0"
                                                     Text="{Binding Id}" />

                                            <StackPanel Grid.Row="2"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="3"
                                                        Margin="0,6,0,0"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBox Width="180"
                                                         Watermark="Bind address"
                                                         IsVisible="{Binding IsUdp}"
                                                         Text="{Binding BindAddress}" />
                                                <TextBox Width="90"
                                                         Watermark="Port"
                                                         IsVisible="{Binding IsUdp}"
                                                         Text="{Binding Port}" />
                                                <TextBox Width="180"
                                                         Watermark="Bind address"
                                                         IsVisible="{Binding IsTcp}"
                                                         Text="{Binding BindAddress}" />
                                                <TextBox Width="90"
                                                         Watermark="Port"
                                                         IsVisible="{Binding IsTcp}"
                                                         Text="{Binding Port}" />
                                                <TextBox Width="380"
                                                         Watermark="File path"
                                                         IsVisible="{Binding IsFile}"
                                                         Text="{Binding FilePath}" />
                                                <TextBox Width="90"
                                                         Watermark="Poll ms"
                                                         IsVisible="{Binding IsFile}"
                                                         Text="{Binding PollIntervalMs}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Column="1"
                                    Spacing="6">
                            <Button Content="Add UDP"
                                    Command="{Binding AddUdpReceiverCommand}" />
                            <Button Content="Add TCP"
                                    Command="{Binding AddTcpReceiverCommand}" />
                            <Button Content="Add File"
                                    Command="{Binding AddFileReceiverCommand}" />
                            <Button Content="Remove"
                                    Command="{Binding RemoveSelectedReceiverCommand}" />
                            <Button Content="Save + Reload"
                                    Command="{Binding SaveReceiverSetupCommand}" />
                            <Button Content="Reload From Disk"
                                    Command="{Binding ReloadReceiverSetupCommand}" />
                            <TextBlock Width="170"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}"
                                       Text="{Binding ReceiverSetupStatus}" />
                        </StackPanel>
                    </Grid>
                </Expander>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="8"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid ColumnDefinitions="260,*"
                  ColumnSpacing="8">
                <Border Grid.Column="0"
                        CornerRadius="8"
                        Padding="8"
                        Background="{DynamicResource ShellBackgroundBrush}">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Margin="2,0,2,6"
                                   Text="Loggers"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding LoggerTreeItems}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate x:DataType="vm:LoggerTreeItemViewModel"
                                                  ItemsSource="{Binding Children}">
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsEnabled}" />
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          Margin="4,0,4,6"
                          ColumnDefinitions="180,90,220,*">
                        <TextBlock Grid.Column="0"
                                   Text="Timestamp"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="Level"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="Logger"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="Message"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                    </Grid>

                    <ListBox x:Name="LogEntriesList"
                             Grid.Row="1"
                             Background="Transparent"
                             ItemsSource="{Binding VisibleEntries}"
                             SelectedItem="{Binding SelectedEntry}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel CacheLength="256" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogEntry">
                                <Border Margin="{Binding DataContext.LogRowMargin, ElementName=MainWindowRoot}"
                                        Background="{Binding Level, Converter={StaticResource LogLevelToRowBrushConverter}}"
                                        CornerRadius="4">
                                    <Grid Margin="4,0"
                                          ColumnDefinitions="180,90,220,*">
                                        <TextBlock Grid.Column="0"
                                                   FontSize="{Binding DataContext.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="{Binding DataContext.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding Level}" />
                                        <TextBlock Grid.Column="2"
                                                   FontSize="{Binding DataContext.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding LoggerName}" />
                                        <TextBlock Grid.Column="3"
                                                   FontSize="{Binding DataContext.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding Message}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="8"
                            CornerRadius="8"
                            Background="{DynamicResource ShellBackgroundBrush}">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Row="0"
                                       Margin="0,0,0,6"
                                       Text="Details"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellForegroundBrush}" />
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedDetailsText}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                            <Grid Grid.Row="2"
                                  Margin="0,8,0,0"
                                  ColumnDefinitions="Auto,Auto,*">
                                <Button Grid.Column="0"
                                        Content="Copy Message"
                                        Command="{Binding CopySelectedMessageCommand}" />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="Copy Details"
                                        Command="{Binding CopySelectedDetailsCommand}" />
                                <TextBlock Grid.Column="2"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}"
                                           Text="{Binding CopyStatus}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
