<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SamLabs.Beobachter.ViewModels"
        xmlns:models="using:SamLabs.Beobachter.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="760"
        x:Class="SamLabs.Beobachter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SamLabs.Beobachter">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource ShellBackgroundBrush}">
        <Border Grid.Row="0"
                Margin="16,16,16,8"
                Padding="14"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Spacing="2">
                    <TextBlock Text="SamLabs.Beobachter"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <TextBlock Text="{Binding ThemeSummary}"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                    <TextBlock Text="{Binding StatusSummary}"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="System"
                            Command="{Binding UseSystemThemeCommand}" />
                    <Button Content="Light"
                            Command="{Binding UseLightThemeCommand}" />
                    <Button Content="Dark"
                            Command="{Binding UseDarkThemeCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,8"
                Padding="12"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid RowDefinitions="Auto,Auto">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <TextBox Grid.Column="0"
                             Watermark="Search logger/message/exception/thread..."
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="Clear"
                            Command="{Binding ClearSearchCommand}" />
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Add Sample"
                            Command="{Binding GenerateSampleEntriesCommand}" />
                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Content="{Binding PauseButtonText}"
                            Command="{Binding TogglePauseCommand}" />
                    <Button Grid.Column="4"
                            Margin="8,0,0,0"
                            Content="{Binding AutoScrollButtonText}"
                            Command="{Binding ToggleAutoScrollCommand}" />
                </Grid>

                <WrapPanel Grid.Row="1"
                           Margin="0,8,0,0">
                    <CheckBox Content="Trace"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowTrace}" />
                    <CheckBox Content="Debug"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowDebug}" />
                    <CheckBox Content="Info"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowInfo}" />
                    <CheckBox Content="Warn"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowWarn}" />
                    <CheckBox Content="Error"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowError}" />
                    <CheckBox Content="Fatal"
                              Margin="0,0,10,0"
                              IsChecked="{Binding ShowFatal}" />
                    <Button Content="Reset Levels"
                            Margin="0,0,10,0"
                            Command="{Binding ResetLevelsCommand}" />
                    <Button Content="Enable All Loggers"
                            Command="{Binding EnableAllLoggersCommand}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="8"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid ColumnDefinitions="260,*"
                  ColumnSpacing="8">
                <Border Grid.Column="0"
                        CornerRadius="8"
                        Padding="8"
                        Background="{DynamicResource ShellBackgroundBrush}">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Margin="2,0,2,6"
                                   Text="Loggers"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding LoggerTreeItems}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate x:DataType="vm:LoggerTreeItemViewModel"
                                                  ItemsSource="{Binding Children}">
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsEnabled}" />
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          Margin="4,0,4,6"
                          ColumnDefinitions="180,90,220,*">
                        <TextBlock Grid.Column="0"
                                   Text="Timestamp"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="Level"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="Logger"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="Message"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                    </Grid>

                    <ListBox x:Name="LogEntriesList"
                             Grid.Row="1"
                             Background="Transparent"
                             ItemsSource="{Binding VisibleEntries}"
                             SelectedItem="{Binding SelectedEntry}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel CacheLength="256" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogEntry">
                                <Grid Margin="4,1"
                                      ColumnDefinitions="180,90,220,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Level}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding LoggerName}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Message}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="8"
                            CornerRadius="8"
                            Background="{DynamicResource ShellBackgroundBrush}">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Row="0"
                                       Margin="0,0,0,6"
                                       Text="Details"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellForegroundBrush}" />
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedDetailsText}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                            <Grid Grid.Row="2"
                                  Margin="0,8,0,0"
                                  ColumnDefinitions="Auto,Auto,*">
                                <Button Grid.Column="0"
                                        Content="Copy Message"
                                        Command="{Binding CopySelectedMessageCommand}" />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="Copy Details"
                                        Command="{Binding CopySelectedDetailsCommand}" />
                                <TextBlock Grid.Column="2"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}"
                                           Text="{Binding CopyStatus}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
