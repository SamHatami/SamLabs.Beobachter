<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        xmlns:views="clr-namespace:SamLabs.Beobachter.Application.Views"
        xmlns:designViewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Design"
        xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="SamLabs.Beobachter.Application.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/SamLabsLogo.png"
        Title="Beobachter"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="0"
        ExtendClientAreaToDecorationsHint="True"
        KeyDown="OnWindowKeyDown">

    <Design.DataContext>
        <designViewModels:MainWindowDesignViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource ShellBackgroundBrush}">

        <Border Grid.Row="0"
                Height="34"
                Background="{DynamicResource ShellPanelBrush}"
                BorderBrush="{DynamicResource ShellPanelBorderBrush}"
                BorderThickness="0,0,0,1"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="0"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center">
                    <svg:Svg Width="20"
                             Height="20"
                             Stretch="Uniform"
                             Margin="4,0,0,0"
                             Path="avares://SamLabs.Beobachter.Application/Assets/SamLabsLogo.svg"/>

                    <TextBlock Text="SamLabs.Beobachter"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="8,-2,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <Button Classes="titlebar-button"
                            Click="OnAppSettingsClick"
                            ToolTip.Tip="Application Settings">
                        <i:Icon Value="fa-solid fa-bars"
                                FontSize="13" />
                    </Button>
                    
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Classes="titlebar-button"
                            Click="OnMinimizeClick"
                            ToolTip.Tip="Minimize">
                        <i:Icon Value="fa-solid fa-minus"
                                FontSize="11" />
                    </Button>
                    <Button Classes="titlebar-button"
                            Click="OnMaximizeClick"
                            ToolTip.Tip="Maximize / Restore">
                        <Grid>
                            <i:Icon x:Name="WindowMaximizeIcon"
                                    Value="fa-regular fa-square"
                                    FontSize="11" />
                            <i:Icon x:Name="WindowRestoreIcon"
                                    Value="fa-regular fa-clone"
                                    FontSize="11"
                                    IsVisible="False" />
                        </Grid>
                    </Button>
                    <Button Classes="titlebar-button titlebar-close-button"
                            Click="OnCloseClick"
                            ToolTip.Tip="Close">
                        <i:Icon Value="fa-solid fa-xmark"
                                FontSize="11" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Workspace (sidebar | splitter | stream panel | splitter | details) -->
        <Grid Grid.Row="1"
              ColumnDefinitions="240,Auto,*,Auto,340">

            <!-- Left sidebar: filters + sources -->
            <ContentControl Grid.Column="0"
                            Content="{Binding WorkspaceSidebar}" />

            <GridSplitter Grid.Column="1"
                          Classes="shell-grid-splitter"
                          ResizeBehavior="PreviousAndNext"
                          />

            <!-- Center: stream search + log stream -->
            <Grid Grid.Column="2"
                  RowDefinitions="Auto,*">
                <ContentControl x:Name="StreamSearchHost"
                                Grid.Row="0"
                                Content="{Binding TopBar}" />
                <ContentControl Grid.Row="1"
                                Content="{Binding Stream}" />
            </Grid>

            <GridSplitter Grid.Column="3"
                          Classes="shell-grid-splitter"
                          ResizeBehavior="PreviousAndNext"
                          />

            <!-- Right: receiver tree + entry details -->
            <Grid Grid.Column="4"
                  RowDefinitions="Auto,*">
                <ContentControl Grid.Row="0"
                                Content="{Binding ReceiverTree}" />
                <ContentControl Grid.Row="1"
                                Content="{Binding Details}" />
            </Grid>
        </Grid>

        <!-- Row 2: Bottom Status Strip -->
        <ContentControl Grid.Row="2"
                        Content="{Binding SessionHealth}" />
    </Grid>
</Window>
