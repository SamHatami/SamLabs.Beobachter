<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:SamLabs.Beobachter.Core.Models"
        xmlns:conv="using:SamLabs.Beobachter.Application.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="760"
        x:Class="SamLabs.Beobachter.Application.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SamLabs.Beobachter"
        KeyDown="OnWindowKeyDown">

    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <conv:LogLevelToRowBrushConverter x:Key="LogLevelToRowBrushConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource ShellBackgroundBrush}">
        <ContentControl Grid.Row="0"
                        Margin="16,16,16,8"
                        Content="{Binding Toolbar}" />

        <Border Grid.Row="1"
                Margin="16,0,16,8"
                Padding="12"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="0"
                             Watermark="Search logger/message/exception/thread..."
                             Text="{Binding Filters.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="Clear"
                            Command="{Binding Filters.ClearSearchCommand}" />
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Add Sample"
                            Command="{Binding GenerateSampleEntriesCommand}" />
                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Content="Col -"
                            Command="{Binding Stream.DecreaseColumnWidthsCommand}" />
                    <Button Grid.Column="4"
                            Margin="8,0,0,0"
                            Content="Col +"
                            Command="{Binding Stream.IncreaseColumnWidthsCommand}" />
                    <Button Grid.Column="5"
                            Margin="8,0,0,0"
                            Content="Col Reset"
                            Command="{Binding Stream.ResetColumnWidthsCommand}" />
                </Grid>

                <WrapPanel Grid.Row="1"
                           Margin="0,8,0,0"
                           ItemHeight="56">
                    <StackPanel Width="140"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Receiver"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="udp-1"
                                 Text="{Binding Filters.ReceiverFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="200"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Logger"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="Orders.Api"
                                 Text="{Binding Filters.LoggerFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="140"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Thread"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="worker-7"
                                 Text="{Binding Filters.ThreadFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="130"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Tenant"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="alpha"
                                 Text="{Binding Filters.TenantFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="130"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Trace Id"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <TextBox Watermark="abcd1234"
                                 Text="{Binding Filters.TraceIdFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Width="120"
                                Margin="0,0,8,0"
                                Spacing="2">
                        <TextBlock Text="Min Level"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <ComboBox ItemsSource="{Binding Filters.MinimumLevelOptions}"
                                  SelectedItem="{Binding Filters.MinimumLevelOption}" />
                    </StackPanel>
                    <Button Content="Clear Fields"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,0"
                            Command="{Binding Filters.ClearStructuredFiltersCommand}" />
                </WrapPanel>

                <WrapPanel Grid.Row="2"
                           Margin="0,8,0,0">
                    <CheckBox Content="Trace"
                              Margin="0,0,10,0"
                              IsChecked="{Binding Filters.ShowTrace}" />
                    <CheckBox Content="Debug"
                              Margin="0,0,10,0"
                              IsChecked="{Binding Filters.ShowDebug}" />
                    <CheckBox Content="Info"
                              Margin="0,0,10,0"
                              IsChecked="{Binding Filters.ShowInfo}" />
                    <CheckBox Content="Warn"
                              Margin="0,0,10,0"
                              IsChecked="{Binding Filters.ShowWarn}" />
                    <CheckBox Content="Error"
                              Margin="0,0,10,0"
                              IsChecked="{Binding Filters.ShowError}" />
                    <CheckBox Content="Fatal"
                              Margin="0,0,10,0"
                              IsChecked="{Binding Filters.ShowFatal}" />
                    <Button Content="Reset Levels"
                            Margin="0,0,10,0"
                            Command="{Binding Filters.ResetLevelsCommand}" />
                    <Button Content="Enable All Loggers"
                            Command="{Binding Sources.EnableAllLoggersCommand}" />
                </WrapPanel>

                <Expander Grid.Row="3"
                          Margin="0,10,0,0"
                          Header="Receiver Setup"
                          IsExpanded="False">
                    <Grid Margin="0,8,0,0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <ListBox Grid.Column="0"
                                 MinHeight="130"
                                 SelectedItem="{Binding ReceiverSetup.SelectedReceiverDefinition}"
                                 ItemsSource="{Binding ReceiverSetup.ReceiverDefinitions}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ReceiverDefinitionViewModel">
                                    <Border Margin="0,0,0,6"
                                            Padding="8"
                                            CornerRadius="6"
                                            Background="{DynamicResource ShellBackgroundBrush}">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                              ColumnDefinitions="120,*,90">
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Kind}"
                                                       FontWeight="SemiBold" />
                                            <TextBox Grid.Row="0"
                                                     Grid.Column="1"
                                                     Margin="8,0,8,0"
                                                     Watermark="Display name"
                                                     Text="{Binding DisplayName}" />
                                            <CheckBox Grid.Row="0"
                                                      Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      Content="Enabled"
                                                      IsChecked="{Binding Enabled}" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="Id" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Grid.ColumnSpan="2"
                                                     Margin="8,6,0,0"
                                                     Text="{Binding Id}" />

                                            <StackPanel Grid.Row="2"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="3"
                                                        Margin="0,6,0,0"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBox Width="180"
                                                         Watermark="Bind address"
                                                         IsVisible="{Binding IsUdp}"
                                                         Text="{Binding BindAddress}" />
                                                <TextBox Width="90"
                                                         Watermark="Port"
                                                         IsVisible="{Binding IsUdp}"
                                                         Text="{Binding Port}" />
                                                <TextBox Width="180"
                                                         Watermark="Bind address"
                                                         IsVisible="{Binding IsTcp}"
                                                         Text="{Binding BindAddress}" />
                                                <TextBox Width="90"
                                                         Watermark="Port"
                                                         IsVisible="{Binding IsTcp}"
                                                         Text="{Binding Port}" />
                                                <TextBox Width="380"
                                                         Watermark="File path"
                                                         IsVisible="{Binding IsFile}"
                                                         Text="{Binding FilePath}" />
                                                <TextBox Width="90"
                                                         Watermark="Poll ms"
                                                         IsVisible="{Binding IsFile}"
                                                         Text="{Binding PollIntervalMs}" />
                                            </StackPanel>

                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="0"
                                                       Margin="0,6,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="Parsers" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Grid.ColumnSpan="2"
                                                     Margin="8,6,0,0"
                                                     ToolTip.Tip="Comma-separated parser names: Log4jXmlParser, JsonLogParser, CsvParser, PlainTextParser"
                                                     Text="{Binding ParserOrderText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Column="1"
                                    Spacing="6">
                            <Button Content="Add UDP"
                                    Command="{Binding ReceiverSetup.AddUdpReceiverCommand}" />
                            <Button Content="Add TCP"
                                    Command="{Binding ReceiverSetup.AddTcpReceiverCommand}" />
                            <Button Content="Add File"
                                    Command="{Binding ReceiverSetup.AddFileReceiverCommand}" />
                            <Button Content="Remove"
                                    Command="{Binding ReceiverSetup.RemoveSelectedReceiverCommand}" />
                            <Button Content="Save + Reload"
                                    Command="{Binding ReceiverSetup.SaveReceiverSetupCommand}" />
                            <Button Content="Reload From Disk"
                                    Command="{Binding ReceiverSetup.ReloadReceiverSetupCommand}" />
                            <TextBlock Width="170"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}"
                                       Text="{Binding ReceiverSetup.ReceiverSetupStatus}" />
                        </StackPanel>
                    </Grid>
                </Expander>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="8"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid ColumnDefinitions="260,*"
                  ColumnSpacing="8">
                <Border Grid.Column="0"
                        CornerRadius="8"
                        Padding="8"
                        Background="{DynamicResource ShellBackgroundBrush}">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Row="0"
                                   Margin="2,0,2,6"
                                   Text="Loggers"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding Sources.LoggerTreeItems}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate x:DataType="viewModels:LoggerTreeItemViewModel"
                                                  ItemsSource="{Binding Children}">
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsEnabled}" />
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        <ContentControl Grid.Row="2"
                                        Margin="0,8,0,0"
                                        Content="{Binding QuickFilters}" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,*,Auto,Auto">
                    <Grid Grid.Row="0"
                          Margin="4,0,4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding Stream.TimestampColumnWidth}" />
                            <ColumnDefinition Width="{Binding Stream.LevelColumnWidth}" />
                            <ColumnDefinition Width="{Binding Stream.LoggerColumnWidth}" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Timestamp"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="Level"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="Logger"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="Message"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                    </Grid>

                    <ListBox x:Name="LogEntriesList"
                             Grid.Row="1"
                             Background="Transparent"
                             ItemsSource="{Binding Stream.VisibleEntries}"
                             SelectedItem="{Binding Stream.SelectedEntry}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel CacheLength="0.5" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogEntry">
                                <Border Margin="{Binding DataContext.Stream.LogRowMargin, ElementName=MainWindowRoot}"
                                        Background="{Binding Level, Converter={StaticResource LogLevelToRowBrushConverter}}"
                                        CornerRadius="4">
                                    <Grid Margin="4,0"
                                          >
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding DataContext.Stream.TimestampColumnWidth, ElementName=MainWindowRoot}" />
                                            <ColumnDefinition Width="{Binding DataContext.Stream.LevelColumnWidth, ElementName=MainWindowRoot}" />
                                            <ColumnDefinition Width="{Binding DataContext.Stream.LoggerColumnWidth, ElementName=MainWindowRoot}" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontSize="{Binding DataContext.Stream.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="{Binding DataContext.Stream.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding Level}" />
                                        <TextBlock Grid.Column="2"
                                                   FontSize="{Binding DataContext.Stream.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding LoggerName}" />
                                        <TextBlock Grid.Column="3"
                                                   FontSize="{Binding DataContext.Stream.LogRowFontSize, ElementName=MainWindowRoot}"
                                                   Text="{Binding Message}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="8"
                            CornerRadius="8"
                            Background="{DynamicResource ShellBackgroundBrush}">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Row="0"
                                       Margin="0,0,0,6"
                                       Text="Details"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellForegroundBrush}" />
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding Details.SelectedDetailsText}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                            <Grid Grid.Row="2"
                                  Margin="0,8,0,0"
                                  ColumnDefinitions="Auto,Auto,*">
                                <Button Grid.Column="0"
                                        Content="Copy Message"
                                        Command="{Binding Details.CopySelectedMessageCommand}" />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="Copy Details"
                                        Command="{Binding Details.CopySelectedDetailsCommand}" />
                                <TextBlock Grid.Column="2"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}"
                                           Text="{Binding Details.CopyStatus}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <ContentControl Grid.Row="3"
                                    Margin="0,8,0,0"
                                    Content="{Binding SessionHealth}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
