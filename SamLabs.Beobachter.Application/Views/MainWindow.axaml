<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SamLabs.Beobachter.Application.Views"
        xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="760"
        x:Class="SamLabs.Beobachter.Application.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SamLabs.Beobachter"
        KeyDown="OnWindowKeyDown">

    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource ShellBackgroundBrush}">
        <ContentControl Grid.Row="0"
                        Margin="16,16,16,8"
                        Content="{Binding Toolbar}" />

        <Border Grid.Row="1"
                Margin="16,0,16,8"
                Padding="12"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid RowDefinitions="Auto,Auto">
                <views:LogQueryBarView x:Name="LogQueryBar"
                                       Grid.Row="0" />
                <views:AdvancedLogFiltersView Grid.Row="1" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="8"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid ColumnDefinitions="260,*"
                  ColumnSpacing="8">
                <ContentControl Grid.Column="0"
                                Content="{Binding WorkspaceSidebar}" />

                <Grid Grid.Column="1"
                      RowDefinitions="*,Auto,Auto">
                    <ContentControl Grid.Row="0"
                                    Content="{Binding Stream}" />

                    <ContentControl Grid.Row="1"
                                    Margin="0,8,0,0"
                                    Content="{Binding Details}" />

                    <ContentControl Grid.Row="2"
                                    Margin="0,8,0,0"
                                    Content="{Binding SessionHealth}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
