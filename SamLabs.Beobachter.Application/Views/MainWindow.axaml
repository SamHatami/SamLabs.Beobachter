<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SamLabs.Beobachter.ViewModels"
        xmlns:models="using:SamLabs.Beobachter.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="760"
        x:Class="SamLabs.Beobachter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SamLabs.Beobachter">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*"
          Background="{DynamicResource ShellBackgroundBrush}">
        <Border Grid.Row="0"
                Margin="16,16,16,8"
                Padding="14"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Spacing="2">
                    <TextBlock Text="SamLabs.Beobachter"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <TextBlock Text="{Binding ThemeSummary}"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                    <TextBlock Text="{Binding StatusSummary}"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="System"
                            Command="{Binding UseSystemThemeCommand}" />
                    <Button Content="Light"
                            Command="{Binding UseLightThemeCommand}" />
                    <Button Content="Dark"
                            Command="{Binding UseDarkThemeCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,8"
                Padding="12"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0"
                         Watermark="Search logger/message/exception/thread..."
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Clear"
                        Command="{Binding ClearSearchCommand}" />
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Content="Add Sample"
                        Command="{Binding GenerateSampleEntriesCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="8"
                CornerRadius="10"
                Background="{DynamicResource ShellPanelBrush}">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0"
                      Margin="4,0,4,6"
                      ColumnDefinitions="180,90,220,*">
                    <TextBlock Grid.Column="0"
                               Text="Timestamp"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="Level"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <TextBlock Grid.Column="2"
                               Text="Logger"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                    <TextBlock Grid.Column="3"
                               Text="Message"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding VisibleEntries}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:LogEntry">
                            <Grid Margin="4,1"
                                  ColumnDefinitions="180,90,220,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Level}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding LoggerName}" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Message}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
