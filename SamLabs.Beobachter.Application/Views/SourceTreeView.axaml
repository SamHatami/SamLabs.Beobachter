<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.SourceTreeView"
             x:DataType="viewModels:SourceTreeViewModel">
    <Border CornerRadius="8"
            Padding="8"
            Background="{DynamicResource ShellBackgroundBrush}">
        <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0"
                       Margin="2,0,2,6"
                       Text="Loggers"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ShellForegroundBrush}" />
            <TreeView Grid.Row="1"
                      ItemsSource="{Binding LoggerTreeItems}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate x:DataType="viewModels:LoggerTreeItemViewModel"
                                      ItemsSource="{Binding Children}">
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsEnabled}" />
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
    </Border>
</UserControl>
