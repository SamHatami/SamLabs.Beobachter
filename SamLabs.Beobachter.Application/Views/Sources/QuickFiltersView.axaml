<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Sources"
             x:Class="SamLabs.Beobachter.Application.Views.Sources.QuickFiltersView"
             x:DataType="viewModels:QuickFiltersViewModel">
    <Border Padding="8"
            CornerRadius="8"
            Background="{DynamicResource ShellBackgroundBrush}">
        <StackPanel Spacing="6">
            <TextBlock Text="Quick Filters"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ShellForegroundBrush}" />
            <Button HorizontalAlignment="Stretch"
                    Content="{Binding ErrorsAndAboveText}"
                    Command="{Binding ApplyErrorsAndAboveCommand}" />
            <Button HorizontalAlignment="Stretch"
                    Content="{Binding StructuredOnlyText}"
                    Command="{Binding ApplyStructuredOnlyCommand}" />
            <Button HorizontalAlignment="Stretch"
                    Content="Clear Quick Filters"
                    Command="{Binding ClearQuickFiltersCommand}" />
        </StackPanel>
    </Border>
</UserControl>
