<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Status"
             x:Class="SamLabs.Beobachter.Application.Views.Status.SessionHealthView"
             x:DataType="viewModels:SessionHealthViewModel">
    <Border Classes="shell-panel shell-flat shell-border-horizontal"
            Padding="12,8">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="16"
                        HorizontalAlignment="Left">
                <TextBlock Text="{Binding ActiveReceiversText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding BufferedEntriesText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding StructuredEventsText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding DroppedPacketsText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <i:Icon Value="fa-solid fa-circle"
                        FontSize="10"
                        IsVisible="{Binding IsRunning}"
                        Foreground="{DynamicResource StatusRunningBrush}" />
                <i:Icon Value="fa-solid fa-square"
                        FontSize="10"
                        IsVisible="{Binding IsPaused}"
                        Foreground="{DynamicResource StatusPausedBrush}" />
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellForegroundBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
