<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Status"
             x:Class="SamLabs.Beobachter.Application.Views.Status.SessionHealthView"
             x:DataType="viewModels:SessionHealthViewModel">
    <Border Padding="12,8"
            CornerRadius="8"
            Background="{DynamicResource ShellPanelBrush}">
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
              ColumnSpacing="16">
            <TextBlock Text="{Binding ActiveReceiversText}"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            <TextBlock Text="{Binding BufferedEntriesText}"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            <TextBlock Text="{Binding StructuredEventsText}"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            <TextBlock Text="{Binding DroppedPacketsText}"
                       Grid.Column="3"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
        </Grid>
    </Border>
</UserControl>
