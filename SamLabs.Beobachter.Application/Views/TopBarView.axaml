<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.TopBarView"
             x:DataType="viewModels:TopBarViewModel">
    <Border Classes="shell-panel shell-flat shell-border-horizontal"
            Padding="14,10">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="14">
            <Border Grid.Column="0"
                    Classes="shell-card"
                    Padding="10,0">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <i:Icon Grid.Column="0"
                            Value="fa-solid fa-magnifying-glass"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             MinHeight="36"
                             BorderThickness="0"
                             Background="Transparent"
                             Watermark="Search logs (e.g. error:timeout AND service:payment)"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
                <Button Classes="toolbar-button"
                        Content="Clear"
                        Command="{Binding ClearSearchCommand}"
                        i:Attached.Icon="fa-solid fa-xmark" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
