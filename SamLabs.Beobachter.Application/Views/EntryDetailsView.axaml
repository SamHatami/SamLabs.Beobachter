<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SamLabs.Beobachter.Application.Converters"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.EntryDetailsView"
             x:DataType="viewModels:EntryDetailsViewModel">
    <UserControl.Resources>
        <conv:LogLevelToRowBrushConverter x:Key="LogLevelToRowBrushConverter" />
    </UserControl.Resources>

    <Border Padding="10"
            Background="{DynamicResource ShellBackgroundBrush}">
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0"
                  IsVisible="{Binding HasSelectedEntry}"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Spacing="6">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Border Padding="8,3"
                                CornerRadius="999"
                                Background="{Binding HeaderLevel, Converter={StaticResource LogLevelToRowBrushConverter}}">
                            <TextBlock Text="{Binding HeaderLevelText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellForegroundBrush}" />
                        </Border>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding HeaderTimestampText}"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                    </StackPanel>

                    <TextBlock Text="{Binding HeaderMessage}"
                               TextWrapping="Wrap"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />

                    <TextBlock Text="{Binding HeaderSourceText}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellForegroundBrush}" />

                    <TextBlock Text="{Binding HeaderContextText}"
                               IsVisible="{Binding HasHeaderContext}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Padding="8,4"
                        Content="Copy Msg"
                        Command="{Binding CopySelectedMessageCommand}" />
                <Button Grid.Column="2"
                        VerticalAlignment="Top"
                        Padding="8,4"
                        Content="Copy All"
                        Command="{Binding CopySelectedDetailsCommand}" />
            </Grid>

            <Border Grid.Row="0"
                    IsVisible="{Binding IsEmptyStateVisible}"
                    Padding="16"
                    CornerRadius="8"
                    Background="{DynamicResource ShellPanelBrush}">
                <TextBlock Text="Select a log entry to inspect its attributes, payload, and exception details."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,0"
                          IsVisible="{Binding HasSelectedEntry}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ATTRIBUTES"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <Border Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource ShellPanelBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="No structured attributes on this entry."
                                           IsVisible="{Binding HasNoAttributes}"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <ItemsControl ItemsSource="{Binding Attributes}"
                                              IsVisible="{Binding HasAttributes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:EntryDetailPropertyViewModel">
                                            <Grid ColumnDefinitions="150,*"
                                                  ColumnSpacing="12">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Key}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="6">
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="RAW JSON PAYLOAD"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <ToggleButton Grid.Column="1"
                                          Padding="8,3"
                                          IsChecked="{Binding IsJsonPayloadView}"
                                          Command="{Binding ShowJsonPayloadCommand}"
                                          Content="JSON" />
                            <ToggleButton Grid.Column="2"
                                          Padding="8,3"
                                          IsChecked="{Binding IsRawPayloadView}"
                                          Command="{Binding ShowRawPayloadCommand}"
                                          Content="Raw" />
                        </Grid>
                        <Border Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource ShellPanelBrush}">
                            <TextBox Text="{Binding PayloadText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     MinHeight="220"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ShellForegroundBrush}" />
                        </Border>
                    </StackPanel>

                    <Expander IsVisible="{Binding HasException}"
                              IsExpanded="{Binding IsExceptionExpanded}">
                        <Expander.Header>
                            <TextBlock Text="EXCEPTION"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        </Expander.Header>
                        <Border Margin="0,8,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource ShellPanelBrush}">
                            <TextBox Text="{Binding ExceptionText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="120"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ShellForegroundBrush}" />
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="2"
                       Margin="0,10,0,0"
                       Text="{Binding CopyStatus}"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
        </Grid>
    </Border>
</UserControl>

