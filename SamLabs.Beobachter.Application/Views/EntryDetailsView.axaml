<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:conv="clr-namespace:SamLabs.Beobachter.Application.Converters"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.EntryDetailsView"
             x:DataType="viewModels:EntryDetailsViewModel">
    <UserControl.Resources>
        <conv:LogLevelToBadgeBrushConverter x:Key="LogLevelToBadgeBrushConverter" />
        <conv:LogLevelToMessageBrushConverter x:Key="LogLevelToMessageBrushConverter" />
        <conv:LogLevelToRowBrushConverter x:Key="LogLevelToRowBrushConverter" />
        <conv:JsonValueKindToBrushConverter x:Key="JsonValueKindToBrushConverter" />
        <conv:ExceptionLineKindToBrushConverter x:Key="ExceptionLineKindToBrushConverter" />
        <conv:ExceptionLineKindToFontWeightConverter x:Key="ExceptionLineKindToFontWeightConverter" />
    </UserControl.Resources>

    <Border Classes="shell-panel shell-flat shell-border-vertical"
            Padding="0">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="0">

            <!-- Panel header: title + pin toggle -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="4,2">
                <TextBlock Grid.Column="0"
                           Text="LOG DETAILS"
                           Classes="panel-title"
                           VerticalAlignment="Center" />
                <ToggleButton Grid.Column="1"
                              Classes="toolbar-button sidebar-header-action"
                              IsChecked="{Binding IsPinned}"
                              Command="{Binding TogglePinCommand}"
                              ToolTip.Tip="Pin panel (keep visible when no entry is selected)"
                              i:Attached.Icon="fa-solid fa-thumbtack" />
            </Grid>

            <!-- Empty state -->
            <Border Grid.Row="1"
                    Classes="shell-card"
                    IsVisible="{Binding IsEmptyStateVisible}"
                    Margin="10,0,10,10"
                    Padding="16">
                <TextBlock Text="Select a log entry to inspect its attributes, payload, and exception details."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            </Border>

            <!-- Two-column body: left = header + attributes, right = payload + exception (right column collapses when both are empty) -->
            <Grid Grid.Row="2"
                  Margin="10,0,10,0"
                  IsVisible="{Binding HasSelectedEntry}"
                  ColumnSpacing="0"
                  MinHeight="160">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{Binding RightColumnWidth}" />
                </Grid.ColumnDefinitions>

                <!-- Left: entry header + attributes -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,0,8,0">
                    <StackPanel Spacing="14">
                        <!-- Toolbar: level badge + timestamp + copy actions -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Border Padding="10,3"
                                    VerticalAlignment="Center"
                                    CornerRadius="{DynamicResource ShellBadgeCornerRadius}"
                                    Background="{Binding HeaderLevel, Converter={StaticResource LogLevelToBadgeBrushConverter}}">
                                <TextBlock Text="{Binding HeaderLevelText}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SeverityBadgeForegroundBrush}" />
                            </Border>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding HeaderTimestampText}"
                                       FontFamily="{DynamicResource ShellMonospaceFontFamily}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <Button Classes="toolbar-button icon-button"
                                    ToolTip.Tip="Copy message"
                                    Command="{Binding CopySelectedMessageCommand}"
                                    i:Attached.Icon="fa-regular fa-copy" />
                            <Button Classes="toolbar-button icon-button"
                                    ToolTip.Tip="Copy full details"
                                    Command="{Binding CopySelectedDetailsCommand}"
                                    i:Attached.Icon="fa-solid fa-file-lines" />
                        </StackPanel>

                        <!-- Hero: level-tinted card containing the message -->
                        <Border CornerRadius="{DynamicResource ShellPanelCornerRadius}"
                                Padding="12,10"
                                BorderThickness="0,0,0,2"
                                BorderBrush="{Binding HeaderLevel, Converter={StaticResource LogLevelToBadgeBrushConverter}}"
                                Background="{Binding HeaderLevel, Converter={StaticResource LogLevelToRowBrushConverter}}">
                            <TextBlock Text="{Binding HeaderMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding HeaderLevel, Converter={StaticResource LogLevelToMessageBrushConverter}}" />
                        </Border>

                        <!-- Metadata: discrete labeled rows (Logger, Receiver, Thread, Host, Call site, Source, Template) -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding HasMetadata}">
                            <TextBlock Text="METADATA"
                                       Classes="section-caption" />
                            <Border Classes="shell-card"
                                    Padding="10">
                                <ItemsControl ItemsSource="{Binding MetadataFields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:EntryDetailPropertyViewModel">
                                            <Grid ColumnDefinitions="110,*,Auto"
                                                  ColumnSpacing="8"
                                                  Margin="0,2">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Key}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Top"
                                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource ShellForegroundBrush}" />
                                                <Button Grid.Column="2"
                                                        Classes="toolbar-button icon-button"
                                                        VerticalAlignment="Top"
                                                        Command="{Binding FilterCommand}"
                                                        ToolTip.Tip="Filter by this value"
                                                        i:Attached.Icon="fa-solid fa-filter" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>

                        <!-- Attributes: structured properties from the log entry -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding HasAttributes}">
                            <TextBlock Text="ATTRIBUTES"
                                       Classes="section-caption" />
                            <Border Classes="shell-card"
                                    Padding="10">
                                <StackPanel Spacing="6">
                                    <ItemsControl ItemsSource="{Binding Attributes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:EntryDetailPropertyViewModel">
                                                <Grid ColumnDefinitions="150,*,Auto"
                                                      ColumnSpacing="8"
                                                      Margin="0,2">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Key}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Top"
                                                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Value}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource ShellForegroundBrush}" />
                                                    <Button Grid.Column="2"
                                                            Classes="toolbar-button icon-button"
                                                            VerticalAlignment="Top"
                                                            Command="{Binding FilterCommand}"
                                                            ToolTip.Tip="Filter by this value"
                                                            i:Attached.Icon="fa-solid fa-filter" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <GridSplitter Grid.Column="1"
                              Margin="4,0"
                              IsVisible="{Binding IsSplitterVisible}"
                              Classes="shell-grid-splitter"
                              ResizeBehavior="PreviousAndNext" />

                <!-- Right: payload + exception -->
                <ScrollViewer Grid.Column="2"
                              IsVisible="{Binding HasRightContent}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding HasPayload}">
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="6">
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="RAW JSON PAYLOAD"
                                           Classes="section-caption" />
                                <ToggleButton Grid.Column="1"
                                              Classes="segment-toggle"
                                              IsChecked="{Binding IsJsonPayloadView}"
                                              Command="{Binding ShowJsonPayloadCommand}"
                                              Content="JSON"
                                              i:Attached.Icon="fa-solid fa-code" />
                                <ToggleButton Grid.Column="2"
                                              Classes="segment-toggle"
                                              IsChecked="{Binding IsRawPayloadView}"
                                              Command="{Binding ShowRawPayloadCommand}"
                                              Content="Raw"
                                              i:Attached.Icon="fa-solid fa-align-left" />
                            </Grid>
                            <Border Classes="shell-card"
                                    Padding="10">
                                <Grid>
                                    <!-- Structured JSON tree (when payload parses) -->
                                    <TreeView ItemsSource="{Binding PayloadTree}"
                                              IsVisible="{Binding IsTreePayloadVisible}"
                                              Background="Transparent"
                                              BorderThickness="0">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate ItemsSource="{Binding Children}"
                                                              x:DataType="viewModels:JsonNodeViewModel">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6"
                                                            Margin="0,1">
                                                    <TextBlock Text="{Binding DisplayKey}"
                                                               FontFamily="{DynamicResource ShellMonospaceFontFamily}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource JsonKeyBrush}" />
                                                    <TextBlock Text="{Binding Preview}"
                                                               FontFamily="{DynamicResource ShellMonospaceFontFamily}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{Binding ValueKind, Converter={StaticResource JsonValueKindToBrushConverter}}" />
                                                </StackPanel>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <!-- Raw text fallback (raw mode, or when JSON parse failed) -->
                                    <TextBox Classes="monospace-display"
                                             Text="{Binding PayloadText}"
                                             IsVisible="{Binding IsRawPayloadVisible}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             Foreground="{DynamicResource ShellForegroundBrush}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Expander IsVisible="{Binding HasException}"
                                  IsExpanded="{Binding IsExceptionExpanded}">
                            <Expander.Header>
                                <TextBlock Text="EXCEPTION"
                                           Classes="section-caption" />
                            </Expander.Header>
                            <Border Margin="0,8,0,0"
                                    Classes="shell-card"
                                    Padding="10">
                                <ItemsControl ItemsSource="{Binding ExceptionLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:ExceptionLineViewModel">
                                            <TextBlock Text="{Binding Text}"
                                                       FontFamily="{DynamicResource ShellMonospaceFontFamily}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       FontWeight="{Binding Kind, Converter={StaticResource ExceptionLineKindToFontWeightConverter}}"
                                                       Foreground="{Binding Kind, Converter={StaticResource ExceptionLineKindToBrushConverter}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <TextBlock Grid.Row="3"
                       Margin="10,4,10,6"
                       Text="{Binding CopyStatus}"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
        </Grid>
    </Border>
</UserControl>
