<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.EntryDetailsView"
             x:DataType="viewModels:EntryDetailsViewModel">
    <Border Padding="8"
            CornerRadius="8"
            Background="{DynamicResource ShellBackgroundBrush}">
        <Grid RowDefinitions="Auto,*,Auto">
            <TextBlock Grid.Row="0"
                       Margin="0,0,0,6"
                       Text="Details"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ShellForegroundBrush}" />
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding SelectedDetailsText}"
                           TextWrapping="Wrap" />
            </ScrollViewer>
            <Grid Grid.Row="2"
                  Margin="0,8,0,0"
                  ColumnDefinitions="Auto,Auto,*">
                <Button Grid.Column="0"
                        Content="Copy Message"
                        Command="{Binding CopySelectedMessageCommand}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Copy Details"
                        Command="{Binding CopySelectedDetailsCommand}" />
                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}"
                           Text="{Binding CopyStatus}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
