<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.ReceiverTreeView"
             x:Name="Root"
             x:DataType="viewModels:ReceiverTreeViewModel">

    <Expander Classes="sidebar-expander"
              IsExpanded="{Binding IsExpanded}">
        <Expander.Header>
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <TextBlock Text="RECEIVERS"
                           Classes="section-caption"
                           VerticalAlignment="Center" />
                <Border Padding="5,1"
                        CornerRadius="{DynamicResource ShellBadgeCornerRadius}"
                        Background="{DynamicResource ShellChromeBrush}"
                        BorderBrush="{DynamicResource ShellChromeBorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding ReceiverSetup.ReceiverDefinitions.Count}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                </Border>
            </StackPanel>
        </Expander.Header>

        <StackPanel Classes="sidebar-expander-content"
                    Spacing="0">

            <!-- Toolbar: Save, Reload, Open Editor -->
            <StackPanel Orientation="Horizontal"
                        Spacing="2"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,6">
                <Button Classes="toolbar-button"
                        Command="{Binding ReceiverSetup.SaveReceiverSetupCommand}"
                        ToolTip.Tip="Save + Reload"
                        i:Attached.Icon="fa-solid fa-floppy-disk" />
                <Button Classes="toolbar-button"
                        Command="{Binding ReceiverSetup.ReloadReceiverSetupCommand}"
                        ToolTip.Tip="Reload from disk"
                        i:Attached.Icon="fa-solid fa-rotate" />
                <Button Classes="toolbar-button"
                        Click="OnOpenEditorClick"
                        ToolTip.Tip="Open receiver editor"
                        i:Attached.Icon="fa-solid fa-gear" />
            </StackPanel>

            <!-- UDP group -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="4"
                  Margin="0,4,0,2">
                <i:Icon Grid.Column="0"
                        Value="fa-solid fa-tower-broadcast"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Grid.Column="1"
                           Text="UDP"
                           Classes="section-caption"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />
                <Button Grid.Column="2"
                        Classes="toolbar-button"
                        Command="{Binding ReceiverSetup.AddUdpReceiverCommand}"
                        ToolTip.Tip="Add UDP receiver"
                        i:Attached.Icon="fa-solid fa-plus" />
            </Grid>

            <ItemsControl ItemsSource="{Binding UdpReceivers}"
                          Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ReceiverDefinitionViewModel">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    MinHeight="26"
                                    Margin="2,1">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        MinWidth="14">
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#22c55e"
                                         IsVisible="{Binding IsRunning}" />
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#ef4444"
                                         IsVisible="{Binding IsFaulted}" />
                                <TextBlock Width="170"
                                           Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12" />
                                <ToggleSwitch
                                    IsChecked="{Binding Enabled, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Enable or disable this receiver" />
                                <Button
                                    Classes="toolbar-button icon-button"
                                    Click="OnEditReceiverClick"
                                    ToolTip.Tip="Edit receiver"
                                    i:Attached.Icon="fa-solid fa-pen" />
                            </StackPanel>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- TCP group -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="4"
                  Margin="0,4,0,2">
                <i:Icon Grid.Column="0"
                        Value="fa-solid fa-ethernet"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Grid.Column="1"
                           Text="TCP"
                           Classes="section-caption"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />
                <Button Grid.Column="2"
                        Classes="toolbar-button"
                        Command="{Binding ReceiverSetup.AddTcpReceiverCommand}"
                        ToolTip.Tip="Add TCP receiver"
                        i:Attached.Icon="fa-solid fa-plus" />
            </Grid>

            <ItemsControl ItemsSource="{Binding TcpReceivers}"
                          Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ReceiverDefinitionViewModel">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    MinHeight="26"
                                    Margin="2,1">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        MinWidth="14">
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#22c55e"
                                         IsVisible="{Binding IsRunning}" />
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#ef4444"
                                         IsVisible="{Binding IsFaulted}" />
                                <TextBlock Width="170"
                                           Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12" />
                                <ToggleSwitch
                                    IsChecked="{Binding Enabled, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Enable or disable this receiver" />
                                <Button
                                    Classes="toolbar-button icon-button"
                                    Click="OnEditReceiverClick"
                                    ToolTip.Tip="Edit receiver"
                                    i:Attached.Icon="fa-solid fa-pen" />
                            </StackPanel>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- File group -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="4"
                  Margin="0,4,0,2">
                <i:Icon Grid.Column="0"
                        Value="fa-regular fa-file-lines"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Grid.Column="1"
                           Text="File"
                           Classes="section-caption"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />
                <Button Grid.Column="2"
                        Classes="toolbar-button"
                        Command="{Binding ReceiverSetup.AddFileReceiverCommand}"
                        ToolTip.Tip="Add file tail receiver"
                        i:Attached.Icon="fa-solid fa-plus" />
            </Grid>

            <ItemsControl ItemsSource="{Binding FileReceivers}"
                          Margin="0,0,0,2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ReceiverDefinitionViewModel">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    MinHeight="26"
                                    Margin="2,1">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        MinWidth="14">
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#22c55e"
                                         IsVisible="{Binding IsRunning}" />
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#ef4444"
                                         IsVisible="{Binding IsFaulted}" />
                                <TextBlock
                                           Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12" />
                                <ToggleSwitch
                                    IsChecked="{Binding Enabled, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Enable or disable this receiver" />
                                <Button
                                    Classes="toolbar-button icon-button"
                                    Click="OnEditReceiverClick"
                                    ToolTip.Tip="Edit receiver"
                                    i:Attached.Icon="fa-solid fa-pen" />
                            </StackPanel>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Expander>

</UserControl>
