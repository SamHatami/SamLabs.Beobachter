<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Toolbar"
             x:Class="SamLabs.Beobachter.Application.Views.Toolbar.MainToolbarView"
             x:DataType="viewModels:MainToolbarViewModel">
    <Border Padding="14"
            CornerRadius="10"
            Background="{DynamicResource ShellPanelBrush}">
        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left"
                        Spacing="2">
                <TextBlock Text="{Binding Title}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShellForegroundBrush}" />
                <TextBlock Text="{Binding ThemeSummary}"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding StatusSummary}"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding StatsSummary1Minute}"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding StatsSummary5Minutes}"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding TopLoggersSummary}"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <TextBlock Text="{Binding TopReceiversSummary}"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button Content="{Binding PauseButtonText}"
                        Command="{Binding TogglePauseCommand}" />
                <Button Content="{Binding AutoScrollButtonText}"
                        Command="{Binding ToggleAutoScrollCommand}" />
                <Button Content="{Binding DensityButtonText}"
                        Command="{Binding ToggleDensityCommand}" />
                <Button Content="System"
                        Command="{Binding UseSystemThemeCommand}" />
                <Button Content="Light"
                        Command="{Binding UseLightThemeCommand}" />
                <Button Content="Dark"
                        Command="{Binding UseDarkThemeCommand}" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
