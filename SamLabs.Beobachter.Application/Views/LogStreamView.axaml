<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SamLabs.Beobachter.Core.Models"
             xmlns:conv="using:SamLabs.Beobachter.Application.Converters"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.LogStreamView"
             x:DataType="viewModels:LogStreamViewModel">
    <UserControl.Resources>
        <conv:LogLevelToRowBrushConverter x:Key="LogLevelToRowBrushConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- View controls row -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="4,0,4,4">
            <Button Content="{Binding DensityButtonText}"
                    Padding="6,2"
                    FontSize="11"
                    Command="{Binding ToggleDensityCommand}" />
            <Button Content="Col -"
                    Padding="6,2"
                    FontSize="11"
                    Command="{Binding DecreaseColumnWidthsCommand}" />
            <Button Content="Col +"
                    Padding="6,2"
                    FontSize="11"
                    Command="{Binding IncreaseColumnWidthsCommand}" />
            <Button Content="Reset"
                    Padding="6,2"
                    FontSize="11"
                    Command="{Binding ResetColumnWidthsCommand}" />
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="1"
              Margin="4,0,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding TimestampColumnWidth}" />
                <ColumnDefinition Width="{Binding LevelColumnWidth}" />
                <ColumnDefinition Width="{Binding LoggerColumnWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Timestamp"
                       FontWeight="SemiBold"
                       FontSize="11"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            <TextBlock Grid.Column="1"
                       Text="Level"
                       FontWeight="SemiBold"
                       FontSize="11"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            <TextBlock Grid.Column="2"
                       Text="Source"
                       FontWeight="SemiBold"
                       FontSize="11"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
            <TextBlock Grid.Column="3"
                       Text="Message"
                       FontWeight="SemiBold"
                       FontSize="11"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
        </Grid>

        <!-- Log entries list -->
        <ListBox x:Name="LogEntriesList"
                 Grid.Row="2"
                 Background="Transparent"
                 ItemsSource="{Binding VisibleEntries}"
                 SelectedItem="{Binding SelectedEntry}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel CacheLength="0.5" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:LogEntry">
                    <Border Margin="{Binding DataContext.LogRowMargin, ElementName=LogEntriesList}"
                            Background="{Binding Level, Converter={StaticResource LogLevelToRowBrushConverter}}"
                            CornerRadius="2">
                        <Grid Margin="4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding DataContext.TimestampColumnWidth, ElementName=LogEntriesList}" />
                                <ColumnDefinition Width="{Binding DataContext.LevelColumnWidth, ElementName=LogEntriesList}" />
                                <ColumnDefinition Width="{Binding DataContext.LoggerColumnWidth, ElementName=LogEntriesList}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="{Binding DataContext.LogRowFontSize, ElementName=LogEntriesList}"
                                       Text="{Binding Timestamp}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="{Binding DataContext.LogRowFontSize, ElementName=LogEntriesList}"
                                       FontWeight="SemiBold"
                                       Text="{Binding Level}" />
                            <TextBlock Grid.Column="2"
                                       FontSize="{Binding DataContext.LogRowFontSize, ElementName=LogEntriesList}"
                                       Text="{Binding LoggerName}" />
                            <TextBlock Grid.Column="3"
                                       FontSize="{Binding DataContext.LogRowFontSize, ElementName=LogEntriesList}"
                                       Text="{Binding Message}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
