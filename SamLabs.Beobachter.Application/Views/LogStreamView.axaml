<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:models="using:SamLabs.Beobachter.Core.Models"
             xmlns:conv="using:SamLabs.Beobachter.Application.Converters"
             xmlns:designViewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels.Design"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             mc:Ignorable="d"
             x:Class="SamLabs.Beobachter.Application.Views.LogStreamView"
             x:DataType="viewModels:LogStreamViewModel">
    <UserControl.Resources>
        <conv:LogLevelToRowBrushConverter x:Key="LogLevelToRowBrushConverter" />
        <conv:LogLevelToMessageBrushConverter x:Key="LogLevelToMessageBrushConverter" />
        <conv:LogLevelToIconConverter x:Key="LogLevelToIconConverter" />
    </UserControl.Resources>

    <Design.DataContext>
        <designViewModels:LogStreamDesignViewModel />
    </Design.DataContext>

    <Border Classes="shell-panel shell-flat shell-border-horizontal"
            Padding="0">
        <Grid RowDefinitions="Auto,Auto,*"
              Grid.IsSharedSizeScope="True"
              RowSpacing="0">
        <Border Grid.Row="0"
                Classes="shell-panel shell-flat shell-border-bottom"
                Padding="10,8">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="RESULTS"
                           Classes="section-caption"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Density and tail controls"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6">
                    <Button Classes="toolbar-button"
                            Content="{Binding DensityButtonText}"
                            ToolTip.Tip="Toggle row density between Comfortable and Compact."
                            Command="{Binding ToggleDensityCommand}"
                            i:Attached.Icon="fa-solid fa-grip-lines" />
                    <Button Classes="toolbar-button"
                            Content="{Binding AutoScrollButtonText}"
                            ToolTip.Tip="Auto-scroll to newest row when new logs arrive."
                            Command="{Binding ToggleAutoScrollCommand}"
                            i:Attached.Icon="fa-solid fa-thumbtack" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="shell-panel shell-flat shell-border-bottom"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="LogTimestampColumn" />
                    <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="LogLevelColumn" />
                    <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="LogSourceColumn" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Margin="0,0,10,0"
                           Text="Timestamp"
                           Classes="section-caption" />
                <TextBlock Grid.Column="1"
                           Margin="0,0,10,0"
                           Text="Level"
                           Classes="section-caption" />
                <TextBlock Grid.Column="2"
                           Margin="0,0,10,0"
                           Text="Source"
                           Classes="section-caption" />
                <TextBlock Grid.Column="3"
                           Text="Message"
                           Classes="section-caption" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Classes="shell-panel shell-flat shell-border-none"
                Padding="2">
            <ListBox x:Name="LogEntriesList"
                     Classes="log-stream-list"
                     Classes.log-stream-density-compact="{Binding IsCompactDensity}"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding VisibleEntries}"
                     SelectedItem="{Binding SelectedEntry}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel CacheLength="0.5" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:LogEntry">
                        <Border Classes="log-stream-item"
                                Background="{Binding Level, Converter={StaticResource LogLevelToRowBrushConverter}}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"
                                                      SharedSizeGroup="LogTimestampColumn" />
                                    <ColumnDefinition Width="Auto"
                                                      SharedSizeGroup="LogLevelColumn" />
                                    <ColumnDefinition Width="Auto"
                                                      SharedSizeGroup="LogSourceColumn" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="{Binding ((viewModels:LogStreamViewModel)DataContext).LogRowFontSize, ElementName=LogEntriesList}"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}"
                                           Text="{Binding Timestamp}" />
                                <i:Icon Grid.Column="1"
                                        Value="{Binding Level, Converter={StaticResource LogLevelToIconConverter}}"
                                        FontSize="{Binding ((viewModels:LogStreamViewModel)DataContext).LogRowFontSize, ElementName=LogEntriesList}"
                                        VerticalAlignment="Center"
                                        Foreground="{Binding Level, Converter={StaticResource LogLevelToMessageBrushConverter}}" />
                                <TextBlock Grid.Column="2"
                                           FontSize="{Binding ((viewModels:LogStreamViewModel)DataContext).LogRowFontSize, ElementName=LogEntriesList}"
                                           Foreground="{DynamicResource ShellForegroundBrush}"
                                           Text="{Binding LoggerName}" />
                                <TextBlock Grid.Column="3"
                                           FontSize="{Binding ((viewModels:LogStreamViewModel)DataContext).LogRowFontSize, ElementName=LogEntriesList}"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToMessageBrushConverter}}"
                                           Text="{Binding Message}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        </Grid>
    </Border>
</UserControl>
