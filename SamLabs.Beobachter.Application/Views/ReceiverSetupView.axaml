<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.ReceiverSetupView"
             x:DataType="viewModels:ReceiverSetupViewModel">
    <Border Classes="shell-panel shell-flat shell-border-none"
            Padding="10">
        <Grid RowDefinitions="Auto,Auto"
              RowSpacing="8">
            <ContentControl Grid.Row="0"
                            Content="{Binding SelectedReceiverDefinition}">
                <ContentControl.DataTemplates>
                    <DataTemplate x:DataType="viewModels:ReceiverDefinitionViewModel">
                        <Border Padding="10"
                                Classes="shell-card">
                            <Grid ColumnDefinitions="110,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="8">
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Type"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="{DynamicResource ShellBadgeCornerRadius}"
                                        Background="{DynamicResource ShellChromeBrush}"
                                        BorderBrush="{DynamicResource ShellChromeBorderBrush}"
                                        BorderThickness="1"
                                        ToolTip.Tip="Receiver transport type.">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <i:Icon Value="fa-solid fa-tower-broadcast"
                                                FontSize="10"
                                                IsVisible="{Binding IsUdp}"
                                                Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <i:Icon Value="fa-solid fa-ethernet"
                                                FontSize="10"
                                                IsVisible="{Binding IsTcp}"
                                                Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <i:Icon Value="fa-regular fa-file-lines"
                                                FontSize="10"
                                                IsVisible="{Binding IsFile}"
                                                Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding Kind}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Name *"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Watermark="Receiver display name"
                                         ToolTip.Tip="Friendly name shown in the UI."
                                         Text="{Binding DisplayName}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Id"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Watermark="receiver-id"
                                         ToolTip.Tip="Unique identifier used by workspace state and filters."
                                         Text="{Binding Id}" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Host"
                                           IsVisible="{Binding IsUdp}"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Host"
                                           IsVisible="{Binding IsTcp}"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <Grid Grid.Row="3"
                                      Grid.Column="1"
                                      ColumnDefinitions="*,90"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsUdp}">
                                    <TextBox Grid.Column="0"
                                             Watermark="localhost"
                                             ToolTip.Tip="Literal IP or localhost, e.g. 0.0.0.0, ::1, or localhost."
                                             Text="{Binding BindAddress}" />
                                    <TextBox Grid.Column="1"
                                             Watermark="7071"
                                             ToolTip.Tip="UDP port (1-65535)."
                                             Text="{Binding Port}" />
                                </Grid>
                                <Grid Grid.Row="3"
                                      Grid.Column="1"
                                      ColumnDefinitions="*,90"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsTcp}">
                                    <TextBox Grid.Column="0"
                                             Watermark="localhost"
                                             ToolTip.Tip="Literal IP or localhost, e.g. 0.0.0.0, ::1, or localhost."
                                             Text="{Binding BindAddress}" />
                                    <TextBox Grid.Column="1"
                                             Watermark="4505"
                                             ToolTip.Tip="TCP port (1-65535)."
                                             Text="{Binding Port}" />
                                </Grid>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="File"
                                           IsVisible="{Binding IsFile}"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <Grid Grid.Row="4"
                                      Grid.Column="1"
                                      ColumnDefinitions="*,90"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsFile}">
                                    <TextBox Grid.Column="0"
                                             Watermark="C:/logs/app.log"
                                             ToolTip.Tip="Absolute path to the log file to tail."
                                             Text="{Binding FilePath}" />
                                    <TextBox Grid.Column="1"
                                             Watermark="150"
                                             ToolTip.Tip="Polling interval in milliseconds."
                                             Text="{Binding PollIntervalMs}" />
                                </Grid>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           VerticalAlignment="Top"
                                           Margin="0,6,0,0"
                                           Text="Parsers"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <WrapPanel Grid.Row="5"
                                           Grid.Column="1"
                                           Orientation="Horizontal">
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,14,6"
                                                Spacing="6">
                                        <ToggleSwitch IsChecked="{Binding IsLog4jXmlParserEnabled}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="Log4jXmlParser" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,14,6"
                                                Spacing="6">
                                        <ToggleSwitch IsChecked="{Binding IsJsonLogParserEnabled}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="JsonLogParser" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,14,6"
                                                Spacing="6">
                                        <ToggleSwitch IsChecked="{Binding IsCsvParserEnabled}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="CsvParser" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,14,6"
                                                Spacing="6">
                                        <ToggleSwitch IsChecked="{Binding IsPlainTextParserEnabled}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="PlainTextParser" />
                                    </StackPanel>
                                </WrapPanel>

                                <StackPanel Grid.Row="6"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="0,4,0,0"
                                            Spacing="2">
                                    <TextBlock Text="{Binding DisplayNameValidationError}"
                                               IsVisible="{Binding HasDisplayNameValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding IdValidationError}"
                                               IsVisible="{Binding HasIdValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding BindAddressValidationError}"
                                               IsVisible="{Binding HasBindAddressValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding PortValidationError}"
                                               IsVisible="{Binding HasPortValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding FilePathValidationError}"
                                               IsVisible="{Binding HasFilePathValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding PollIntervalValidationError}"
                                               IsVisible="{Binding HasPollIntervalValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding ParserOrderValidationError}"
                                               IsVisible="{Binding HasParserOrderValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
            <TextBlock Grid.Row="1"
                       Text="{Binding ReceiverSetupStatus}"
                       IsVisible="{Binding HasReceiverSetupStatus}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
        </Grid>
    </Border>
</UserControl>
