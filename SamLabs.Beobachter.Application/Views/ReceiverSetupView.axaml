<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.ReceiverSetupView"
             x:DataType="viewModels:ReceiverSetupViewModel">
    <Border Classes="shell-panel shell-flat shell-border-none"
            Padding="10">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="8">

            <!-- Toolbar -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="6">
                <Button Classes="receiver-setup-button primary"
                        Content="Save + Reload"
                        ToolTip.Tip="Save receiver settings and restart receiver transports."
                        Command="{Binding SaveReceiverSetupCommand}"
                        i:Attached.Icon="fa-solid fa-floppy-disk" />
                <Button Classes="receiver-setup-button"
                        Content="Reload From Disk"
                        ToolTip.Tip="Discard unsaved edits and reload definitions from settings files."
                        Command="{Binding ReloadReceiverSetupCommand}"
                        i:Attached.Icon="fa-solid fa-rotate" />
                <Button Classes="receiver-setup-button"
                        Content="Remove"
                        ToolTip.Tip="Remove this receiver."
                        Command="{Binding RemoveSelectedReceiverCommand}"
                        i:Attached.Icon="fa-solid fa-trash" />
            </StackPanel>

            <!-- Status -->
            <TextBlock Grid.Row="1"
                       Text="{Binding ReceiverSetupStatus}"
                       IsVisible="{Binding HasReceiverSetupStatus}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

            <!-- Single receiver form -->
            <ContentControl Grid.Row="2"
                            Content="{Binding SelectedReceiverDefinition}">
                <ContentControl.DataTemplates>
                    <DataTemplate x:DataType="viewModels:ReceiverDefinitionViewModel">
                        <Border Padding="10"
                                Classes="shell-card">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="130,*,118">

                                <!-- Row 0: type badge + display name + enabled -->
                                <Border Grid.Row="0"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        CornerRadius="{DynamicResource ShellBadgeCornerRadius}"
                                        Background="{DynamicResource ShellChromeBrush}"
                                        BorderBrush="{DynamicResource ShellChromeBorderBrush}"
                                        BorderThickness="1"
                                        ToolTip.Tip="Receiver transport type."
                                        HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <i:Icon Value="fa-solid fa-tower-broadcast"
                                                FontSize="10"
                                                IsVisible="{Binding IsUdp}"
                                                Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <i:Icon Value="fa-solid fa-ethernet"
                                                FontSize="10"
                                                IsVisible="{Binding IsTcp}"
                                                Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <i:Icon Value="fa-regular fa-file-lines"
                                                FontSize="10"
                                                IsVisible="{Binding IsFile}"
                                                Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding Kind}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                                    </StackPanel>
                                </Border>
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,8,0"
                                         Watermark="Display name"
                                         ToolTip.Tip="Friendly name shown in the UI."
                                         Text="{Binding DisplayName}" />
                                <CheckBox Grid.Row="0"
                                          Grid.Column="2"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="Enable or disable this receiver."
                                          Content="Enabled"
                                          IsChecked="{Binding Enabled}" />

                                <!-- Row 1: Id -->
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,6,0,0"
                                           VerticalAlignment="Center"
                                           Text="Id"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="8,6,0,0"
                                         ToolTip.Tip="Unique identifier used by workspace state and filters."
                                         Text="{Binding Id}" />

                                <!-- Row 2: transport-specific fields -->
                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Margin="0,6,0,0"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <TextBox Width="180"
                                             Watermark="Bind address"
                                             IsVisible="{Binding IsUdp}"
                                             ToolTip.Tip="Literal IP address only, e.g. 0.0.0.0 or ::1."
                                             Text="{Binding BindAddress}" />
                                    <TextBox Width="90"
                                             Watermark="Port"
                                             IsVisible="{Binding IsUdp}"
                                             ToolTip.Tip="UDP port (1-65535)."
                                             Text="{Binding Port}" />
                                    <TextBox Width="180"
                                             Watermark="Bind address"
                                             IsVisible="{Binding IsTcp}"
                                             ToolTip.Tip="Literal IP address only, e.g. 0.0.0.0 or ::1."
                                             Text="{Binding BindAddress}" />
                                    <TextBox Width="90"
                                             Watermark="Port"
                                             IsVisible="{Binding IsTcp}"
                                             ToolTip.Tip="TCP port (1-65535)."
                                             Text="{Binding Port}" />
                                    <TextBox Width="380"
                                             Watermark="File path"
                                             IsVisible="{Binding IsFile}"
                                             ToolTip.Tip="Absolute path to the log file to tail."
                                             Text="{Binding FilePath}" />
                                    <TextBox Width="90"
                                             Watermark="Poll ms"
                                             IsVisible="{Binding IsFile}"
                                             ToolTip.Tip="Polling interval in milliseconds."
                                             Text="{Binding PollIntervalMs}" />
                                </StackPanel>

                                <!-- Row 3: parsers -->
                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="0,6,0,0"
                                           VerticalAlignment="Center"
                                           Text="Parsers"
                                           Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="8,6,0,0"
                                         ToolTip.Tip="Comma-separated parser names: Log4jXmlParser, JsonLogParser, CsvParser, PlainTextParser"
                                         Text="{Binding ParserOrderText}" />

                                <!-- Row 4: validation errors -->
                                <StackPanel Grid.Row="4"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Margin="0,8,0,0"
                                            Spacing="2">
                                    <TextBlock Text="{Binding DisplayNameValidationError}"
                                               IsVisible="{Binding HasDisplayNameValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding IdValidationError}"
                                               IsVisible="{Binding HasIdValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding BindAddressValidationError}"
                                               IsVisible="{Binding HasBindAddressValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding PortValidationError}"
                                               IsVisible="{Binding HasPortValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding FilePathValidationError}"
                                               IsVisible="{Binding HasFilePathValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding PollIntervalValidationError}"
                                               IsVisible="{Binding HasPollIntervalValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                    <TextBlock Text="{Binding ParserOrderValidationError}"
                                               IsVisible="{Binding HasParserOrderValidationError}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ValidationErrorBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>
