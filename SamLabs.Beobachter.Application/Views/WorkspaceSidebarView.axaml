<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:viewModels="clr-namespace:SamLabs.Beobachter.Application.ViewModels"
             x:Class="SamLabs.Beobachter.Application.Views.WorkspaceSidebarView"
             x:Name="Root"
             x:DataType="viewModels:WorkspaceSidebarViewModel">
    <Border Classes="shell-panel shell-flat shell-border-vertical"
            Padding="0">
        <ScrollViewer Classes="sidebar-scroll">
            <StackPanel Spacing="0"
                        HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto"
                      Margin="10,10,10,8">
                    <TextBlock Grid.Column="0"
                               Text="FILTERS"
                               Classes="panel-title" />
                    <Button Grid.Column="1"
                            Classes="toolbar-button"
                            Command="{Binding ClearAllFiltersCommand}"
                            Content="Clear All"
                            i:Attached.Icon="fa-solid fa-broom" />
                </Grid>

                <Expander Classes="sidebar-expander"
                          IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="LOG LEVEL"
                                   Classes="section-caption" />
                    </Expander.Header>
                    <StackPanel Classes="sidebar-expander-content"
                                Spacing="0">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="8"
                              RowSpacing="2">
                            <CheckBox Grid.Row="0"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Filters.ShowError}" />
                            <i:Icon Grid.Row="0"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Value="fa-solid fa-circle-xmark"
                                    FontSize="11"
                                    Foreground="{DynamicResource MessageErrorBrush}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="Error"
                                       Foreground="{DynamicResource MessageErrorBrush}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{Binding ErrorCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <CheckBox Grid.Row="1"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Filters.ShowWarn}" />
                            <i:Icon Grid.Row="1"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Value="fa-solid fa-triangle-exclamation"
                                    FontSize="11"
                                    Foreground="{DynamicResource MessageWarnBrush}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="Warn"
                                       Foreground="{DynamicResource MessageWarnBrush}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{Binding WarnCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <CheckBox Grid.Row="2"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Filters.ShowInfo}" />
                            <i:Icon Grid.Row="2"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Value="fa-solid fa-circle-info"
                                    FontSize="11"
                                    Foreground="{DynamicResource MessageInfoBrush}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="Info"
                                       Foreground="{DynamicResource MessageInfoBrush}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{Binding InfoCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <CheckBox Grid.Row="3"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Filters.ShowDebug}" />
                            <i:Icon Grid.Row="3"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Value="fa-solid fa-bug"
                                    FontSize="11"
                                    Foreground="{DynamicResource MessageDebugBrush}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="Debug"
                                       Foreground="{DynamicResource MessageDebugBrush}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{Binding DebugCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <CheckBox Grid.Row="4"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Filters.ShowTrace}" />
                            <i:Icon Grid.Row="4"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Value="fa-solid fa-wave-square"
                                    FontSize="11"
                                    Foreground="{DynamicResource MessageTraceBrush}" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="Trace"
                                       Foreground="{DynamicResource MessageTraceBrush}" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{Binding TraceCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />

                            <CheckBox Grid.Row="5"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Filters.ShowFatal}" />
                            <i:Icon Grid.Row="5"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Value="fa-solid fa-skull-crossbones"
                                    FontSize="11"
                                    Foreground="{DynamicResource MessageFatalBrush}" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="Fatal"
                                       Foreground="{DynamicResource MessageFatalBrush}" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{Binding FatalCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander Classes="sidebar-expander"
                          IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="FILTER PRESETS"
                                   Classes="section-caption" />
                    </Expander.Header>
                    <StackPanel Classes="sidebar-expander-content"
                                Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <ToggleButton Grid.Column="0"
                                          Classes="filter-chip"
                                          IsChecked="{Binding QuickFilters.IsErrorsAndAboveEnabled}"
                                          Content="Errors and above" />
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding QuickFilters.ErrorsAndAboveCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <ToggleButton Grid.Column="0"
                                          Classes="filter-chip"
                                          IsChecked="{Binding QuickFilters.IsStructuredOnlyEnabled}"
                                          Content="Structured only" />
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding QuickFilters.StructuredOnlyCount}"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander Classes="sidebar-expander"
                          IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="SOURCE / SERVICE"
                                   Classes="section-caption" />
                    </Expander.Header>
                    <StackPanel Classes="sidebar-expander-content"
                                Spacing="8">
                        <TextBox Watermark="Filter sources..."
                                 Text="{Binding Sources.SourceSearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <ItemsControl ItemsSource="{Binding Sources.VisibleSourceItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4"
                                          ColumnDefinitions="Auto,*,Auto">
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsEnabled}" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Name}"
                                                   Foreground="{DynamicResource ShellForegroundBrush}" />
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Count}"
                                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

                <Expander Classes="sidebar-expander"
                          IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="HOST"
                                   Classes="section-caption" />
                    </Expander.Header>
                    <StackPanel Classes="sidebar-expander-content"
                                Spacing="6">
                        <TextBlock Text="Quick host filters"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <ItemsControl ItemsSource="{Binding HostOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4"
                                          ColumnDefinitions="*,Auto">
                                        <ToggleButton Grid.Column="0"
                                                      Classes="filter-chip"
                                                      IsChecked="{Binding IsSelected}"
                                                      Command="{Binding ((viewModels:WorkspaceSidebarViewModel)DataContext).ApplyHostFacetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" 
                                                      Content="{Binding Label}" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Count}"
                                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

                <Expander Classes="sidebar-expander"
                          IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="STRUCTURED FIELDS"
                                   Classes="section-caption" />
                    </Expander.Header>
                    <StackPanel Classes="sidebar-expander-content"
                                Spacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Receiver"
                                       FontSize="11"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <TextBox Watermark="udp-1"
                                     Text="{Binding Filters.ReceiverFilter, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Logger"
                                       FontSize="11"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <TextBox Watermark="Orders.Api"
                                     Text="{Binding Filters.LoggerFilter, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Thread"
                                       FontSize="11"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <TextBox Watermark="worker-7"
                                     Text="{Binding Filters.ThreadFilter, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Min Level"
                                       FontSize="11"
                                       Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                            <ComboBox ItemsSource="{Binding Filters.MinimumLevelOptions}"
                                      SelectedItem="{Binding Filters.MinimumLevelOption}" />
                        </StackPanel>

                        <!-- Dynamic property filters discovered from the stream -->
                        <TextBlock Text="PROPERTIES"
                                   Classes="section-caption"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="No properties seen yet. Properties appear as log entries arrive."
                                   IsVisible="{Binding !Filters.HasPropertyFilters}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <ItemsControl ItemsSource="{Binding Filters.PropertyFilters}"
                                      IsVisible="{Binding Filters.HasPropertyFilters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:PropertyFilterItemViewModel">
                                    <StackPanel Spacing="2"
                                                Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Key}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="4">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1"
                                                    Classes="toolbar-button"
                                                    Command="{Binding ClearValueCommand}"
                                                    ToolTip.Tip="Clear"
                                                    i:Attached.Icon="fa-solid fa-xmark" />
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

                <Expander Classes="sidebar-expander"
                          IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="TAGS"
                                   Classes="section-caption" />
                    </Expander.Header>
                    <StackPanel Classes="sidebar-expander-content"
                                Spacing="6">
                        <TextBlock Text="Click a tag chip to narrow the search."
                                   Foreground="{DynamicResource ShellMutedForegroundBrush}" />
                        <ItemsControl ItemsSource="{Binding TagOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Margin="0,0,6,6"
                                                  Classes="filter-chip"
                                                  IsChecked="{Binding IsSelected}"
                                                  Command="{Binding ((viewModels:WorkspaceSidebarViewModel)DataContext).ApplyTagFacetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"
                                                  Content="{Binding Label}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
